---
interface SeoVariant {
  title: string;
  description: string;
  keywords: string;
}

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  ogDescription?: string;
  seoEn?: SeoVariant;
  seoEs?: SeoVariant;
  ldJson?: object | object[];
}

const {
  title,
  description = "Krijoni shkallë notash profesionale falas. Vendosni notën maksimale, minimale dhe kaluese dhe gjeneroni automatikisht shpërndarjen e plotë të notave të nxënësve tuaj.",
  keywords = "llogaritës notash, shkalla e notave, mjet falas mësues, vlerësim nxënësish, tabela e notave, nota kaluese, kalkulator notash shqip",
  canonical = "https://scalegrades.com/",
  ogDescription,
  seoEn = {
    title: "Grade Scale Calculator — Free Tool for Teachers | ScaleGrades",
    description: "Free grade scale calculator for teachers. Set maximum, minimum, and passing grades to instantly generate a complete student grade distribution table.",
    keywords: "grade scale calculator, grading scale, teacher grade calculator, grade distribution table, pass fail grade calculator, free grading tool",
  },
  seoEs = {
    title: "Calculadora de Escala de Notas — Herramienta Gratis para Profesores | ScaleGrades",
    description: "Crea escalas de notas profesionales gratis. Configura nota máxima, mínima y de aprobación para generar automáticamente la distribución de notas de tus alumnos.",
    keywords: "calculadora escala de notas, tabla de notas, herramienta para profesores, distribución de notas, calcular nota aprobación, escala de calificaciones gratis",
  },
  ldJson = {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "ScaleGrades",
    "url": "https://scalegrades.com",
    "description": "Free grade scale calculator for teachers. Set maximum, minimum and passing grades to instantly generate a complete student grade distribution table.",
    "applicationCategory": "EducationApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "featureList": [
      "Grade scale calculator",
      "Multi-country grade systems",
      "Albanian, English and Spanish support",
      "Automatic grade distribution table"
    ],
    "inLanguage": [
      { "@type": "Language", "name": "English",  "alternateName": "en" },
      { "@type": "Language", "name": "Albanian", "alternateName": "sq" },
      { "@type": "Language", "name": "Spanish",  "alternateName": "es" }
    ],
    "audience": { "@type": "Audience", "audienceType": "Teachers" }
  },
} = Astro.props;

const resolvedOgDescription = ogDescription || description;
---

<!doctype html>
<html lang="sq">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />

    <!-- Canonical & hreflang -->
    <link rel="canonical"  id="link-canonical"   href={canonical} />
    <link rel="alternate"  hreflang="x-default"  href={canonical} />
    <link rel="alternate"  hreflang="sq"          href={canonical} />
    <link rel="alternate"  hreflang="en"          href={canonical} />

    <!-- SEO parazgjedhëse — shqip (ndryshon nga JS sipas vendndodhjes) -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords"    content={keywords} />

    <!-- Open Graph -->
    <meta property="og:type"              content="website" />
    <meta property="og:site_name"         content="ScaleGrades" />
    <meta property="og:url"               content={canonical} />
    <meta property="og:title"             content={title} />
    <meta property="og:description"       content={resolvedOgDescription} />
    <meta property="og:locale"            content="sq_AL" />
    <meta property="og:locale:alternate"  content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={resolvedOgDescription} />

    <!-- JSON-LD Structured Data (static, crawler-friendly) -->
    <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />

    <!-- Dynamic SEO: overrides title/meta based on detected IP language -->
    <script define:vars={{ pageTitle: title, pageDescription: description, pageKeywords: keywords, pageCanonical: canonical, seoEn, seoEs }} is:inline>
      const _SEO = {
        al: {
          lang: 'sq',
          title: pageTitle,
          description: pageDescription,
          keywords: pageKeywords,
          ogLocale: 'sq_AL',
        },
        en: {
          lang: 'en',
          title: seoEn.title,
          description: seoEn.description,
          keywords: seoEn.keywords,
          ogLocale: 'en_US',
        },
        es: {
          lang: 'es',
          title: seoEs.title,
          description: seoEs.description,
          keywords: seoEs.keywords,
          ogLocale: 'es_ES',
        }
      };

      // Countries in the Americas (non-Spanish non-English → Albanian second default)
      const _AMERICAS = new Set(['US','CA','MX','GT','HN','SV','NI','CR','PA','CU','DO','PR','JM','TT','BB','HT','CL','AR','CO','PE','VE','BO','EC','PY','UY','BR','GY','SR','BZ','GF','GP','MQ']);

      // Direct country → internal language code mapping (Spanish commented out)
      const _GEO = {
        AL:'al', XK:'al',
        // ES:'es', CL:'es', AR:'es', CO:'es', PE:'es', VE:'es', BO:'es', EC:'es', PY:'es', UY:'es',
        // MX:'es', GT:'es', HN:'es', SV:'es', NI:'es', CR:'es', PA:'es', CU:'es', DO:'es',
        US:'en', CA:'en', AU:'en', GB:'en', NZ:'en', IE:'en', ZA:'en', PH:'en',
      };

      // Country-name → language (Spanish commented out for now)
      const _PAIS_LANG = { albania:'al', estados_unidos:'en' /*, chile:'es', espana:'es', mexico:'es' */ };

      async function _detectLang() {
        // Derivar idioma del país guardado (evita valores stale de gscale_idioma)
        const savedPais = localStorage.getItem('gscale_pais');
        if (savedPais && _PAIS_LANG[savedPais]) return _PAIS_LANG[savedPais];
        try {
          const r = await fetch('https://ipapi.co/json/');
          const d = await r.json();
          const code = d.country_code;
          if (_GEO[code]) return _GEO[code];
          if (!_AMERICAS.has(code)) return 'al';
        } catch (_) {}
        return 'en';
      }

      function _setMeta(sel, attr, val) {
        let el = document.querySelector(sel);
        if (!el) { el = document.createElement('meta'); document.head.appendChild(el); }
        el.setAttribute(attr, val);
      }

      (async function () {
        const lang = await _detectLang();
        const seo  = _SEO[lang] || _SEO.al;
        const url  = 'https://scalegrades.com' + window.location.pathname;

        document.title = seo.title;
        document.documentElement.lang = seo.lang;

        _setMeta('meta[name="description"]',       'content', seo.description);
        _setMeta('meta[name="keywords"]',           'content', seo.keywords);
        _setMeta('meta[property="og:title"]',       'content', seo.title);
        _setMeta('meta[property="og:description"]', 'content', seo.description);
        _setMeta('meta[property="og:locale"]',      'content', seo.ogLocale);
        _setMeta('meta[property="og:url"]',         'content', url);
        _setMeta('meta[name="twitter:title"]',       'content', seo.title);
        _setMeta('meta[name="twitter:description"]', 'content', seo.description);

        const canonical = document.getElementById('link-canonical');
        if (canonical) canonical.href = url;
      })();
    </script>

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" />

    <!-- Google Analytics 4 — reemplaza G-Z46VHH4WTV con tu Measurement ID -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Z46VHH4WTV" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Z46VHH4WTV');
    </script>
  </head>
  <body style="display: flex; flex-direction: column; min-height: 100vh; margin: 0;">
    <slot name="header"></slot>
    <main style="flex: 1;">
      <slot />
    </main>
    <slot name="footer"></slot>
    <script src="/js/navbar.js" is:inline></script>
  </body>
  <style is:global>
    * {
      box-sizing: border-box;
      margin: 0;
    }

    section {
      font-family: Arial, sans-serif;
      padding: 15px;
    }

    input,
    select,
    button {
      margin: 5px 0;
      transition: 0.5s ease all;
    }
  </style>
</html>
