---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <script is:inline>
      // Meta tags dinámicos según idioma
      const metaData = {
        al: {
          title: "Shkalla e notave - Mjet falas për profesorë",
          description: "Mjet falas për llogaritjen e shkallës së notave dhe vlerësimin e performancës së studentëve në mënyrë efektive dhe të saktë.",
          keywords: "llogaritja e notave, shkalla e notave, mjete për profesorë, vlerësimi i studentëve",
          ogTitle: "Shkalla e notave - Mjet falas për profesorë",
          ogDescription: "Zbuloni se si mjeti ynë ndihmon profesorët të llogarisin shkallat e notave dhe të përmirësojnë vlerësimin në klasë."
        },
        en: {
          title: "Grade Scale - Free tool for teachers",
          description: "Free tool for teachers to calculate grade scales and evaluate student performance effectively and accurately.",
          keywords: "grade calculation, grade scale, tools for teachers, student assessment",
          ogTitle: "Grade Scale - Free tool for teachers",
          ogDescription: "Discover how our tool helps teachers calculate grade scales and improve classroom assessment."
        },
        es: {
          title: "Escala de notas - Herramienta gratuita para profesores",
          description: "Herramienta gratuita para profesores para calcular escalas de notas y evaluar el rendimiento estudiantil de manera efectiva y precisa.",
          keywords: "calculo de notas, escalas de notas, herramientas para profesores, evaluación estudiantil",
          ogTitle: "Escala de notas - Herramienta gratuita para profesores",
          ogDescription: "Descubre cómo nuestra herramienta ayuda a profesores a calcular escalas de notas y mejorar la evaluación en el aula."
        }
      };

      // Detectar idioma y aplicar meta tags
      async function applyMetaTags() {
        let lang = 'es';
        try {
          const response = await fetch('http://ip-api.com/json/?fields=countryCode');
          const data = await response.json();
          if (data.countryCode === 'AL') lang = 'al';
          else if (data.countryCode === 'US') lang = 'en';
          else if (!['ES', 'CL', 'MX'].includes(data.countryCode)) lang = 'en';
        } catch(e) {
          lang = 'en';
        }
        
        const meta = metaData[lang] || metaData.es;
        
        // Actualizar meta tags
        document.title = meta.title;
        
        let desc = document.querySelector('meta[name="description"]');
        if (!desc) {
          desc = document.createElement('meta');
          desc.name = 'description';
          document.head.appendChild(desc);
        }
        desc.content = meta.description;
        
        let keys = document.querySelector('meta[name="keywords"]');
        if (!keys) {
          keys = document.createElement('meta');
          keys.name = 'keywords';
          document.head.appendChild(keys);
        }
        keys.content = meta.keywords;
        
        let ogDesc = document.querySelector('meta[property="og:description"]');
        if (!ogDesc) {
          ogDesc = document.createElement('meta');
          ogDesc.property = 'og:description';
          document.head.appendChild(ogDesc);
        }
        ogDesc.content = meta.ogDescription;
        
        // Actualizar html lang
        document.documentElement.lang = lang;
      }
      
      applyMetaTags();
    </script>
    
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css"
    />
  </head>
  <body style="display: flex; flex-direction: column; min-height: 100vh; margin: 0;">
    <slot name="header"></slot>
  <main style="flex: 1;">
    <slot />
  </main>
  <slot name="footer"></slot>
  </body>
  <style is:global>
    * {
      box-sizing: border-box;
      margin: 0;
    }

    section {
      font-family: Arial, sans-serif;
      padding: 15px;
    }

    input,
    select,
    button {
      margin: 5px 0;
      transition: 0.5s ease all;
    }
  </style>
</html>