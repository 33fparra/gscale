<style>
  nav {
    background-color: #1e212a;
  }
  .custom-select {
    width: 90px;
    position: relative;
  }

  .selected-flag {
    padding: 5px;
    width: 48px;
    cursor: pointer;
  }

  .options-container {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    padding: 3px;
    z-index: 1;
    background: #212735;
    border-radius: 10px;
    width: 55px;
  }

  .option {
    padding: 4px;
    cursor: pointer;
  }

  .option:hover {
    border-radius: 10px;
    background-color: #333b4e;
  }
  
  .view-toggle {
    display: flex;
    gap: 10px;
  }
  
  .view-btn {
    padding: 8px 16px;
    border-radius: 5px;
    cursor: pointer;
    font-weight: bold;
    transition: all 0.3s ease;
  }
  
  .view-btn.active {
    background: #eab308;
    color: #1e212a;
  }
  
  .view-btn.inactive {
    background: #333b4e;
    color: #9ca3af;
  }
  
  .nav-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  
  @media (min-width: 768px) {
    .nav-container {
      flex-direction: row;
      justify-content: center;
    }
  }
</style>
<nav class="px-4 fixed top-0 w-full z-10 shadow-xl">
  <div class="max-w-6xl mx-auto p-2 sm:p-0">
    <div class="flex justify-center p-2 sm:p-4">
      <div class="nav-container">
        <div class="view-toggle">
          <a href="/" class="view-btn active" id="btn-docente">Docente</a>
          <a href="/alumno" class="view-btn inactive" id="btn-alumno">Alumno</a>
        </div>
        <div class="py-1 px-1 custom-select md:inline-block" id="customSelect">
          <div class="selected-flag">
            <img
              src="/img/chile.svg"
              alt="Selected Country"
              id="selectedFlagImage"
            />
          </div>
          <div class="options-container" id="optionsContainer">
            <div class="option" data-value="estados_unidos">
              <img src="/img/estados-unidos.svg" alt="Estados Unidos" />
            </div>
            <div class="option" data-value="albania">
              <img src="/img/albania.svg" alt="Albania" />
            </div>
            <div class="option" data-value="chile">
              <img src="/img/chile.svg" alt="Chile" />
            </div>
            <div class="option" data-value="espana">
              <img src="/img/espana.svg" alt="España" />
            </div>
            <div class="option" data-value="mexico">
              <img src="/img/mexico.svg" alt="México" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  // Actualizar estado de botones según la página actual
  const path = window.location.pathname;
  const btnDocente = document.getElementById('btn-docente');
  const btnAlumno = document.getElementById('btn-alumno');
  
  if (path.includes('alumno')) {
    btnDocente.classList.remove('active');
    btnDocente.classList.add('inactive');
    btnAlumno.classList.remove('inactive');
    btnAlumno.classList.add('active');
  } else {
    btnAlumno.classList.remove('active');
    btnAlumno.classList.add('inactive');
    btnDocente.classList.remove('inactive');
    btnDocente.classList.add('active');
  }
</script>