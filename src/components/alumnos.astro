<h2 class="text-2xl font-bold text-center mb-4 mt-4" id="titulo-alumno">Calcula mi promedio</h2>
<div class="flex flex-col items-center">
	<div class="w-auto mx-2 mb-0 p-4 shadow-lg h-full caja">
		<div class="flex gap-4">
			<div class="w-full flex">
				<div class="flex w-full pr-1 items-center">
					<label
						for="notaMaxima"
						class="text-xs block text-gray-500 font-bold mb-1 md:mb-0 w-1/2"
						id="label-notaMaxima"
					>
						Nota máxima:
					</label>
					<input
						type="number"
						id="notaMaxima"
						value="10"
						placeholder="10"
						class="w-1/2 bg-gray-200 appearance-none border-2 border-gray-200 rounded px-2 py-1 text-xs text-gray-700 leading-tight focus:outline-none focus:bg-white focus:border-purple-500"
					/>
				</div>
			</div>
			<div class="w-full flex">
				<div class="flex w-full pr-1 items-center">
					<label
						for="notaMinima"
						class="text-xs block text-gray-500 font-bold mb-1 md:mb-0 w-1/2"
						id="label-notaMinima"
					>
						Nota mínima:
					</label>
					<input
						type="number"
						id="notaMinima"
						value="1"
						placeholder="1"
						class="w-1/2 bg-gray-200 appearance-none border-2 border-gray-200 rounded px-2 py-1 text-xs text-gray-700 leading-tight focus:outline-none focus:bg-white focus:border-purple-500"
					/>
				</div>
			</div>
		</div>
		<div class="flex gap-4">
			<div class="w-full flex">
				<div class="flex w-full pr-1 items-center">
					<label
						for="notaEximir"
						class="text-xs block text-gray-500 font-bold mb-1 md:mb-0 w-1/2"
						id="label-notaEximir"
					>
						Nota eximirse:
					</label>
					<input
						type="number"
						id="notaEximir"
						value="7"
						placeholder="7"
						class="w-1/2 bg-gray-200 appearance-none border-2 border-gray-200 rounded px-2 py-1 text-xs text-gray-700 leading-tight focus:outline-none focus:bg-white focus:border-purple-500"
					/>
				</div>
			</div>
			<div class="w-full flex">
				<div class="flex w-full pr-1 items-center">
					<label
						for="notaAprobar"
						class="text-xs block text-gray-500 font-bold mb-1 md:mb-0 w-1/2"
						id="label-notaAprobar"
					>
						Nota aprobar:
					</label>
					<input
						type="number"
						id="notaAprobar"
						value="4"
						placeholder="4"
						class="w-1/2 bg-gray-200 appearance-none border-2 border-gray-200 rounded px-2 py-1 text-xs text-gray-700 leading-tight focus:outline-none focus:bg-white focus:border-purple-500"
					/>
				</div>
			</div>
		</div>
		<hr class="my-2" />
		<div id="sections">
			<div class="section" id="section1">
				<div class="flex gap-4">
					<div class="w-full flex">
						<div class="flex w-full pr-1 items-center">
							<label
								class="text-xs block text-gray-500 font-bold mb-1 md:mb-0 w-1/2"
								id="label-nombre-seccion"
							>
								Nombre de sección:
							</label>
							<input
								type="text"
								placeholder="Taller, Cátedra, etc..."
								class="section-name w-1/2 bg-gray-200 appearance-none border-2 border-gray-200 rounded px-2 py-1 text-xs text-gray-700 leading-tight focus:outline-none focus:bg-white focus:border-purple-500"
							/>
						</div>
					</div>
					<div class="w-full flex">
						<div class="flex w-full pr-1 items-center">
							<label
								class="text-xs block text-gray-500 font-bold mb-1 md:mb-0 w-1/2"
								id="label-pondera-seccion"
							>
								Pondera la sección:
							</label>
							<input
								type="text"
								placeholder="%"
								class="section-weight w-1/2 bg-gray-200 appearance-none border-2 border-gray-200 rounded px-2 py-1 text-xs text-gray-700 leading-tight focus:outline-none focus:bg-white focus:border-purple-500"
							/>
						</div>
					</div>
				</div>
				<div class="flex gap-4 notes">
					<div class="w-full flex">
						<div class="flex w-full pr-1 items-center">
							<label
								class="text-xs block text-gray-500 font-bold mb-1 md:mb-0 w-1/2"
								id="label-nota-seccion"
							>
								Nota:
							</label>
							<input
								type="number"
								placeholder="Nota"
								class="note w-1/2 bg-gray-200 appearance-none border-2 border-gray-200 rounded px-2 py-1 text-xs text-gray-700 leading-tight focus:outline-none focus:bg-white focus:border-purple-500"
							/>
						</div>
					</div>
					<div class="w-full flex">
						<div class="flex w-full pr-1 items-center">
							<label
								class="text-xs block text-gray-500 font-bold mb-1 md:mb-0 w-1/2"
								id="label-pondera-nota"
							>
								Pondera la nota:
							</label>
							<input
								type="number"
								placeholder="%"
								class="note-weight w-1/2 bg-gray-200 appearance-none border-2 border-gray-200 rounded px-2 py-1 text-xs text-gray-700 leading-tight focus:outline-none focus:bg-white focus:border-purple-500"
							/>
						</div>
					</div>
				</div>
				<div class="w-full mx-auto flex justify-center gap-2">
					<button
						class="w-max py-2 px-4 text-white rounded text-xs text-orange-500 hover:text-orange-300 add-note-btn"
						style="background: #212735;"
						id="btn-agregar-nota"
					>
						Agregar nota
					</button>
					<button
						class="w-max py-2 px-3 bg-red-500 text-white rounded text-xs delete-note-btn"
						style="background: #f97316;"
					>
						<i class="fas fa-trash"></i>
					</button>
				</div>
				<div class="section-average text-center font-bold mt-2" id="label-promedio-seccion">
					Promedio de la sección: <span></span>
				</div>
			</div>
		</div>
	</div>
	<div class="w-full mx-auto flex mt-4 justify-center gap-2">
		<button
			class="w-max py-2 px-4 text-white rounded text-xs text-orange-500 hover:text-orange-300 add-section-btn"
			style="background: #212735;"
			id="btn-agregar-seccion"
		>
			Agregar sección
		</button>
		<button
			class="w-max py-2 px-3 bg-red-500 text-white rounded text-xs delete-section-btn"
			style="background: #f97316;"
		>
			<i class="fas fa-trash"></i>
		</button>
	</div>
	<div class="w-full mx-auto flex justify-center">
		<button
			class="w-max py-2 px-4 my-1 text-white rounded text-xs text-orange-500 hover:text-orange-300 calculate-grade-btn"
			style="background: #212735;"
			id="btn-calcular-final"
		>
			Calcular Nota Final
		</button>
	</div>
	<div id="result" class="font-bold my-4"></div>
	<div id="eximirse" class="font-bold my-4"></div>
</div>
<!-- END section -->

<script src="/js/alumnos.js" is:inline></script>
