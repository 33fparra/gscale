<script is:inline>
  function showTab(id) {
    document.querySelectorAll('.tab-panel').forEach(function (el) {
      el.classList.add('hidden');
    });
    document.querySelectorAll('.tab-btn').forEach(function (el) {
      el.classList.remove('active');
    });
    var panel = document.getElementById('panel-' + id);
    var btn   = document.getElementById('tab-' + id);
    if (panel) panel.classList.remove('hidden');
    if (btn)   btn.classList.add('active');

    /* animate bars in newly shown panel */
    setTimeout(function () {
      if (!panel) return;
      panel.querySelectorAll('.abar[data-w]').forEach(function (b) {
        b.style.width = b.dataset.w;
      });
    }, 60);
  }

  /* Animate bars in the default (first) tab on load */
  window.addEventListener('load', function () {
    setTimeout(function () {
      var firstPanel = document.getElementById('panel-karriera');
      if (!firstPanel) return;
      firstPanel.querySelectorAll('.abar[data-w]').forEach(function (b) {
        b.style.width = b.dataset.w;
      });
    }, 350);
  });
</script>
