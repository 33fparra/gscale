---
import LayoutInfo from "../layouts/LayoutInfo.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "@/components/footer.astro";
---

<LayoutInfo
  title="Si e njoh fëmijën tim? — Test për Prindër | ScaleGrades"
  description="Test falas për prindër — zbulo pikat e forta të fëmijës dhe si ta shoqërosh në zgjedhjen e karrierës pa e shtypur."
  canonical="https://scalegrades.com/prinderit"
>
  <Navbar slot="header" />
  <link rel="stylesheet" href="/js/test-styles.css" />

  <div class="pp-back-bar">
    <a href="/" class="pp-back-link"><i class="fas fa-arrow-left"></i> Kthehu në Faqen Kryesore</a>
  </div>

  <section class="pp-landing">
    <div class="pp-intro-badge"><i class="fas fa-heart"></i> Test për Prindër</div>
    <h1 class="pp-landing-title">Si e njoh fëmijën tim?</h1>
    <p class="pp-landing-sub">
      Një test i shkurtër prej 21 pyetjesh që ju ndihmon të kuptoni pikat e forta të fëmijës suaj dhe pritshmëritë tuaja si prind.
      Në fund merrni një profil të personalizuar me këshilla konkrete se si ta mbështesni në zgjedhjen e shkollës dhe karrierës.
    </p>
    <ul class="pp-landing-bullets">
      <li><i class="fas fa-compass"></i> Zbuloni fushat ku fëmija juaj shkëlqen më shumë</li>
      <li><i class="fas fa-balance-scale"></i> Krahasoni pritshmëritë tuaja me prirjet reale të tij/saj</li>
      <li><i class="fas fa-lightbulb"></i> Merrni këshilla konkrete si ta mbështesni pa e shtypur</li>
    </ul>
    <button class="pp-landing-cta" onclick="document.getElementById('app').scrollIntoView({behavior:'smooth'})">
      Fillo Testin <i class="fas fa-arrow-down"></i>
    </button>
  </section>

  <div id="app" style="min-height:100vh;"></div>

  <Footer slot="footer" />
</LayoutInfo>

<style is:global>
  body { background-color: #1e212a !important; color: #e5e7eb; }

  .pp-back-bar {
    position: fixed; top: 62px; left: 0; right: 0; z-index: 50;
    background: #1e212a; border-bottom: 1px solid #2a3042; padding: 8px 20px;
  }
  .pp-back-link {
    display: inline-flex; align-items: center; gap: 7px;
    color: #6b7280; text-decoration: none; font-size: 0.8rem; font-weight: 600;
    transition: color 0.18s;
  }
  .pp-back-link:hover { color: #9ca3af; }

  .pp-container { max-width: 800px; margin: 0 auto; padding: 112px 20px 80px; min-height: 100vh; }

  .pp-intro-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(59,130,246,0.12); border: 1px solid rgba(59,130,246,0.3);
    border-radius: 99px; padding: 6px 14px; font-size: 0.8rem; color: #60a5fa; margin-bottom: 14px;
  }
  .pp-intro-card { background: #2a3042; border: 1px solid #333b4e; border-radius: 16px; padding: 32px 28px; margin-top: 20px; }
  .pp-form-group { margin-bottom: 22px; }
  .pp-label { display: block; font-size: 0.8rem; color: #9ca3af; font-weight: 700; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.06em; }
  .pp-input {
    width: 100%; background: #1e212a; border: 1.5px solid #333b4e; border-radius: 9px;
    padding: 13px 16px; color: #e5e7eb; font-size: 1rem; font-family: inherit;
    outline: none; transition: border-color 0.2s; box-sizing: border-box;
  }
  .pp-input:focus { border-color: #3b82f6; }
  .pp-btn-row { display: flex; gap: 10px; }
  .pp-sel-btn {
    flex: 1; padding: 11px 6px; border-radius: 9px; border: 1.5px solid #333b4e;
    background: #1e212a; color: #9ca3af; font-size: 0.88rem; font-weight: 600;
    cursor: pointer; transition: all 0.2s; font-family: inherit; white-space: nowrap;
  }
  .pp-sel-btn:hover { border-color: #3b82f6; color: #60a5fa; }
  .pp-sel-btn.pp-sel { background: rgba(59,130,246,0.15); border-color: #3b82f6; color: #93c5fd; }

  /* Likert */
  .kk-likert-scale { margin-top: 18px; }
  .kk-likert-btns { display: flex; gap: 8px; margin-bottom: 7px; }
  .kk-likert-labels { display: flex; justify-content: space-between; }
  .kk-likert-label { font-size: 0.68rem; color: #4b5563; }
  .kk-likert-btn {
    flex: 1; padding: 12px 6px; border: 2px solid #333b4e; border-radius: 10px;
    background: #1e212a; color: #9ca3af; font-size: 0.95rem; font-weight: 700;
    cursor: pointer; transition: all 0.22s ease; text-align: center; font-family: inherit;
  }
  .kk-likert-btn:hover { border-color: #3b82f6; color: #60a5fa; background: rgba(59,130,246,0.05); }
  .kk-likert-btn.kk-likert-sel[data-val="1"] { background:#fb7185; border-color:#fb7185; color:#1e212a; }
  .kk-likert-btn.kk-likert-sel[data-val="2"] { background:#f97316; border-color:#f97316; color:#1e212a; }
  .kk-likert-btn.kk-likert-sel[data-val="3"] { background:#fbbf24; border-color:#fbbf24; color:#1e212a; }
  .kk-likert-btn.kk-likert-sel[data-val="4"] { background:#60a5fa; border-color:#60a5fa; color:#1e212a; }
  .kk-likert-btn.kk-likert-sel[data-val="5"] { background:#7c3aed; border-color:#7c3aed; color:#fff; }

  .pp-padre-badge {
    display: inline-flex; align-items: center; gap: 6px; font-size: 0.75rem; font-weight: 700;
    padding: 4px 12px; border-radius: 20px; background: rgba(96,165,250,0.1);
    color: #60a5fa; border: 1px solid rgba(96,165,250,0.25);
  }

  .pp-section-banner {
    background: linear-gradient(135deg,rgba(59,130,246,0.08),rgba(124,58,237,0.08));
    border: 1px solid rgba(59,130,246,0.2); border-radius: 14px;
    padding: 24px; text-align: center; margin-bottom: 20px;
  }
  .pp-section-icon { font-size: 2rem; margin-bottom: 8px; }
  .pp-section-banner h3 { font-size: 1.1rem; font-weight: 800; color: #93c5fd; margin-bottom: 6px; }
  .pp-section-banner p { font-size: 0.85rem; color: #6b7280; line-height: 1.5; }

  .pp-result-area-card { background: #2a3042; border-radius: 14px; padding: 22px 24px; border: 1px solid #333b4e; }
  .pp-area-header { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; }
  .pp-area-icon { font-size: 1.5rem; }
  .pp-area-name { font-size: 1.1rem; font-weight: 800; margin: 0; }
  .pp-area-rank { font-size: 0.7rem; font-weight: 700; padding: 3px 10px; border-radius: 99px; white-space: nowrap; }
  .pp-area-desc { font-size: 0.87rem; color: #9ca3af; line-height: 1.65; margin-bottom: 10px; }
  .pp-area-market { font-size: 0.82rem; color: #6b7280; line-height: 1.55; display: flex; gap: 8px; align-items: flex-start; }
  .pp-area-market i { flex-shrink: 0; margin-top: 2px; }

  .pp-section-title {
    font-size: 0.78rem; font-weight: 700; color: #6b7280; text-transform: uppercase;
    letter-spacing: 0.07em; margin: 24px 0 12px; display: flex; align-items: center; gap: 8px;
  }
  .pp-section-title i { color: #3b82f6; }

  .pp-balance-card {
    background: linear-gradient(135deg,#2a3042,#333b4e); border: 1px solid rgba(59,130,246,0.3);
    border-radius: 14px; padding: 22px 24px; font-size: 0.9rem; color: #d1d5db;
    line-height: 1.75; margin-bottom: 8px; box-shadow: 0 0 30px rgba(59,130,246,0.06);
  }

  .pp-rec-card {
    background: #2a3042; border: 1px solid #333b4e; border-radius: 12px;
    padding: 18px 20px; display: flex; gap: 14px; align-items: flex-start;
  }
  .pp-rec-icon { font-size: 1.6rem; flex-shrink: 0; line-height: 1; }
  .pp-rec-label { font-size: 0.72rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 5px; }
  .pp-rec-text { font-size: 0.88rem; color: #d1d5db; line-height: 1.6; margin: 0; }

  .pp-blog-links { display: flex; flex-direction: column; gap: 8px; margin-bottom: 8px; }
  .pp-blog-link {
    display: flex; align-items: center; gap: 8px; padding: 13px 16px;
    background: #2a3042; border: 1px solid #333b4e; border-radius: 10px;
    color: #60a5fa; text-decoration: none; font-size: 0.87rem; font-weight: 600;
    transition: all 0.18s;
  }
  .pp-blog-link:hover { border-color: #3b82f6; background: rgba(59,130,246,0.06); color: #93c5fd; }
  .pp-blog-link i { color: #3b82f6; flex-shrink: 0; }

  /* ── LANDING ────────────────────────────────────────────────────────── */
  .pp-landing {
    max-width: 800px; margin: 0 auto; padding: 112px 20px 60px;
    min-height: 100vh; display: flex; flex-direction: column; justify-content: center;
  }
  .pp-landing-title {
    font-size: 2.4rem; font-weight: 900; color: #fff;
    margin: 14px 0 16px; letter-spacing: -0.02em; line-height: 1.15;
  }
  .pp-landing-sub {
    color: #9ca3af; font-size: 1rem; line-height: 1.75; margin-bottom: 28px; max-width: 600px;
  }
  .pp-landing-bullets {
    list-style: none; padding: 0; margin: 0 0 32px; display: flex; flex-direction: column; gap: 12px;
  }
  .pp-landing-bullets li {
    display: flex; align-items: flex-start; gap: 12px; color: #d1d5db; font-size: 0.95rem;
    line-height: 1.5; background: #2a3042; border: 1px solid #333b4e; border-radius: 12px; padding: 14px 18px;
  }
  .pp-landing-bullets li i { color: #3b82f6; margin-top: 3px; flex-shrink: 0; }
  .pp-landing-cta {
    display: inline-flex; align-items: center; gap: 10px; align-self: flex-start;
    background: #3b82f6; color: #fff; font-weight: 800; font-size: 1rem;
    padding: 16px 32px; border-radius: 12px; border: none; cursor: pointer;
    transition: all 0.2s; box-shadow: 0 8px 24px rgba(59,130,246,0.25); font-family: inherit;
  }
  .pp-landing-cta:hover { background: #60a5fa; transform: translateY(-2px); }

  @media (max-width: 600px) {
    .pp-container { padding: 100px 16px 60px; }
    .pp-btn-row { gap: 6px; }
    .pp-sel-btn { font-size: 0.8rem; padding: 10px 4px; }
    .kk-likert-btns { gap: 6px; }
    .kk-likert-btn { padding: 10px 4px; font-size: 0.88rem; }

    .pp-landing { padding: 100px 16px 50px; min-height: auto; }
    .pp-landing-title { font-size: 1.8rem; }
    .pp-landing-sub { font-size: 0.92rem; }
    .pp-landing-cta { width: 100%; justify-content: center; }
  }
</style>

