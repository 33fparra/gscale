  }
  .anav-btn:hover { border-color: #7c3aed; background: #faf5ff; }
  .anav-btn small { display: block; font-size: 0.72rem; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
  .anav-btn span { display: block; font-size: 0.88rem; font-weight: 700; }
  .anav-btn i { color: #7c3aed; flex-shrink: 0; }
  .anav-btn-right { justify-content: flex-end; text-align: right; }
</style>
