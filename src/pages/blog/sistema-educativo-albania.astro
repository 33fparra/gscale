                <th style="padding:10px 14px; text-align:left;">Level</th>
                <th style="padding:10px 14px; text-align:left;">Description</th>
              </tr></thead>
              <tbody>
                {[["10","Excellent","Maximum possible mark"],["9","Very Good","Exceptional performance"],["8","Good","High performance"],["7","Above Average","Above standard requirements"],["6","Satisfactory","Meets requirements"],["5","Sufficient","Minimum acceptable"],["4","Minimum Pass","⚠️ Passing threshold"],["1–3","Failed","Below minimum requirements"]].map(([n,v,d],i) => (
                  <tr style={`${i%2===0?'background:#fafafa;':'background:#fff;'}${n==='4'?' border-left:3px solid #f97316;':n==='1–3'?' border-left:3px solid #7c3aed;':''}`}>
